# Groq API — get your key at https://console.groq.com/
GROQ_API_KEY=gsk_your_key_here

# LLM settings
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.3

# Recommendation defaults
MAX_CANDIDATES_FOR_LLM=20
DEFAULT_TOP_K=5

# Dataset cache (created automatically after first load)
# Local: ./data/cache/restaurants.parquet
# Railway (ephemeral): /tmp/data/cache/restaurants.parquet
# Railway (volume mounted at /data): /data/cache/restaurants.parquet
DATASET_CACHE_PATH=./data/cache/restaurants.parquet

# Budget tiers (cost for two, in INR)
BUDGET_LOW_MAX=500
BUDGET_MEDIUM_MAX=1500

# API CORS (comma-separated origins; no trailing slashes)
# Local dev:
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Production (Railway) — add your Vercel URL after deploy:
# CORS_ORIGINS=https://your-project.vercel.app

# Logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
